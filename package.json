{
  "name": "petfit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop-pet-lite/PetFitBudingPet.ps1",
    "desktop:test": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop-pet-lite/PetFitBudingPet.ps1 -SelfTest",
    "desktop:build": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop-pet-lite/build-lite-package.ps1",
    "android:sync": "pnpm run build && cap sync android",
    "android:build": "pnpm run android:sync && cd android && gradlew.bat --init-script init-repositories.gradle assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
